# Copie este arquivo para .env e preencha os valores.
# Na VPS, cada ambiente tem seu proprio .env:
#   ~/fintazz/production/.env
#   ~/fintazz/dev/.env

# MongoDB Atlas
MongoDbSettings__Host=
MongoDbSettings__Username=
MongoDbSettings__Password=
MongoDbSettings__AppName=
MongoDbSettings__DatabaseName=

# JWT (API only)
JwtSettings__SecretKey=
JwtSettings__Issuer=Fintazz
JwtSettings__Audience=FintazzUsers
JwtSettings__AccessTokenExpirationMinutes=15
JwtSettings__RefreshTokenExpirationDays=7

# CORS (API only)
AllowedOrigins__0=https://fintazz.homelandtech.cloud

# E-mail (SMTP)
EmailSettings__SmtpHost=
EmailSettings__SmtpPort=587
EmailSettings__Username=
EmailSettings__Password=
EmailSettings__FromEmail=
EmailSettings__FromName=Fintazz
EmailSettings__AppBaseUrl=
